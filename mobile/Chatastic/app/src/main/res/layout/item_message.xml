<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="top">

    <!-- Square avatar for incoming messages (shown on left) -->
    <View
        android:id="@+id/avatarIncoming"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <!-- Message bubble — wrap_content so it doesn't span full width -->
    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:background="@color/light_gray"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Sender name — visible for group context, hidden for outgoing by code -->
        <TextView
            android:id="@+id/senderText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/contentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/timeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#888888"
            android:layout_gravity="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Square avatar for outgoing messages (shown on right) -->
    <View
        android:id="@+id/avatarOutgoing"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="#FFFFFF"
        android:visibility="gone" />

</LinearLayout>
